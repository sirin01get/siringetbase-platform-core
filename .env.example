# ---------------------------------------------------------------------------
# Siringetbase Platform Core — environment variables (Phase 0 scaffold)
# Copy to .env.local for local dev. Never commit real values — see
# ../security/README.md Tier 1: these are infrastructure secrets.
# ---------------------------------------------------------------------------

# Supabase — Postgres system of record for identity + payments (siringetbase schema)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Publishable key (sb_publishable_...) — Supabase dashboard > Settings > API
# Keys > "Publishable and secret API keys" tab. If you only see anon/service_role
# keys, click "Create new API keys" first (safe — legacy keys keep working
# alongside the new ones until you deactivate them).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# Server-side only, never exposed to the client. Used by the entity-graph
# sync job and payments escrow primitives, which act across role_profiles
# that aren't necessarily the calling user's own.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Neo4j — the Entity Graph (see ../entity-graph/README.md)
NEO4J_URI=neo4j+s://YOUR-INSTANCE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
# Optional — defaults to "neo4j" if unset, which is correct for most fresh
# AuraDB Free/Professional instances but not universal. If /api/diagnostics
# reports Neo.ClientError.Database.DatabaseNotFound, check Aura console →
# your instance → Connect (or run `SHOW DATABASES` in Neo4j Browser) for the
# real name and set it here.
# NEO4J_DATABASE=neo4j

# Cloudflare (deployment)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Payments — which mock adapter is active (see ../payments/README.md).
# Provider names, not secrets — real values once a real integration exists
# would be separate Worker Secrets (e.g. RAZORPAY_API_KEY), not this var.
PAYMENT_GATEWAY_PROVIDER=razorpay-mock
BANK_PAYOUT_PROVIDER=icici-mock

# Comms — shared email pipeline (see ../comms/README.md).
# Resend dashboard → API Keys. Must be able to send from a domain you've
# verified in Resend (SPF/DKIM/DMARC) — see COMMS_FROM_EMAIL below.
RESEND_API_KEY=re_your_resend_api_key
# Supabase dashboard → Authentication → Hooks → Send Email → after pointing
# it at this deployed app's /api/comms/auth-email-hook, Supabase shows this
# secret exactly once, in the exact "v1,whsec_..." form expected here.
SEND_EMAIL_HOOK_SECRET=v1,whsec_your_hook_secret
# The From: address every comms email is sent as. The domain portion MUST
# be verified in Resend's dashboard (Domains → Add Domain → add the SPF/
# DKIM/DMARC records it gives you) or every send silently fails/bounces —
# see ../comms/README.md's Rollout Plan step 1. email.siringet.com is
# already Verified in Resend, so this is the real value, not a placeholder.
COMMS_FROM_EMAIL="CA Focus <onboarding@email.siringet.com>"
